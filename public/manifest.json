{
    "manifest_version": 3,
    "name": "Wiki Game",
    "description": "__MSG_manifest_description__",
    "version": "1.1.0",
    "icons": {
        "48": "images/logo-48.png",
        "128": "images/logo-128.png"
    },
    "permissions": ["storage"],
    "background": {
        "service_worker": "service-worker.js"
    },
    "default_locale": "en",
    "content_scripts": [
        {
            "css": ["./styles.css"],
            "js": ["./content.js"],
            "matches": ["https://*.wikipedia.org/*", "https://*.fandom.com/*", "https://*.wiktionary.org/*"],
            "run_at": "document_end"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["images/*"],
            "matches": ["https://*.wikipedia.org/*", "https://*.fandom.com/*", "https://*.wiktionary.org/*"]
        }
    ]
}

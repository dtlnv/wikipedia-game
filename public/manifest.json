{
    "manifest_version": 3,
    "name": "Wiki Game",
    "description": "'Wiki Game' is an exciting web-based game where players start from any Wiki page and aim to reach a random target article by clicking on hyperlinks within the content.",
    "version": "1.1.1000",
    "icons": {
        "48": "images/logo-48.png",
        "128": "images/logo-128.png"
    },
    "permissions": ["storage", "tabs", "sidePanel"],
    "background": {
        "service_worker": "service-worker.js"
    },
    "content_scripts": [
        {
            "css": ["./styles.css"],
            "js": ["./content.js"],
            "matches": ["https://*.wikipedia.org/*", "https://*.fandom.com/wiki/*", "https://*.wiktionary.org/*"],
            "run_at": "document_end"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["images/*"],
            "matches": ["https://*.wikipedia.org/*", "https://*.fandom.com/wiki/*", "https://*.wiktionary.org/*"]
        }
    ]
}

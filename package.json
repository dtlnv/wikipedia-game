{
    "name": "wiki-game",
    "version": "2.0.0",
    "description": "'Wiki Game' is an exciting web-based game where players start from any Wiki page and aim to reach a random target article by clicking on hyperlinks within the content.",
    "keywords": [],
    "author": "dtlnv",
    "license": "ISC",
    "repository": {
        "type": "git",
        "url": "https://github.com/dtlnv/wiki-game"
    },
    "scripts": {
        "build": "rm -rf build && webpack --mode production",
        "create-zip": "npm run build && node archive.js",
        "test": "jest --coverage",
        "lint": "biome check",
        "lint:fix": "biome check --write",
        "format": "biome format --write",
        "typescript": "tsc --noEmit"
    },
    "dependencies": {
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/preset-env": "^7.29.0",
        "@biomejs/biome": "^2.4.6",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/chrome": "^0.1.37",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.3.5",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "archiver": "^7.0.1",
        "babel-loader": "^10.1.0",
        "clean-webpack-plugin": "^4.0.0",
        "copy-webpack-plugin": "^14.0.0",
        "css-loader": "^7.1.4",
        "css-minimizer-webpack-plugin": "^8.0.0",
        "jest": "^30.2.0",
        "jest-environment-jsdom": "^30.2.0",
        "mini-css-extract-plugin": "^2.10.0",
        "sass": "^1.97.3",
        "sass-loader": "^16.0.7",
        "terser-webpack-plugin": "^5.3.17",
        "ts-jest": "^29.4.6",

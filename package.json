{
    "name": "wiki-game",
    "version": "1.0.3",
    "description": "'Wikipedia Game' is an exciting web-based game where players start from any Wikipedia page and aim to reach a random target article by clicking on hyperlinks within the content.",
    "keywords": [],
    "author": "dtlnv",
    "license": "ISC",
    "repository": {
        "type": "git",
        "url": "https://github.com/dtlnv/wikipedia-game"
    },
    "scripts": {
        "build": "rm -rf build && webpack --mode production",
        "create-zip": "npm run build && node archive.ts",
        "test": "react-scripts test --no-cache --watchAll=false --coverage --collectCoverageFrom=src/**/*.{js,jsx,ts,tsx}",
        "prettier": "npx prettier --write .",
        "lint": "biome check",
        "lint:fix": "biome check --apply",
        "format": "biome format --write",
        "typescript": "tsc --noEmit"
    },
    "dependencies": {
        "react": "^19.2.1",
        "react-dom": "^19.2.1"
    },
    "devDependencies": {
        "@babel/core": "^7.28.5",
        "@babel/preset-env": "^7.28.5",
        "@biomejs/biome": "^2.3.8",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/chrome": "^0.1.32",
        "@types/jest": "^30.0.0",
        "@types/node": "^24.10.1",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "archiver": "^7.0.1",
        "babel-loader": "^10.0.0",
        "clean-webpack-plugin": "^4.0.0",
        "copy-webpack-plugin": "^13.0.1",
        "css-loader": "^7.1.2",
        "css-minimizer-webpack-plugin": "^7.0.2",
        "mini-css-extract-plugin": "^2.9.4",
        "prettier": "^3.7.4",
        "react-scripts": "^5.0.1",
        "sass": "^1.94.2",
        "sass-loader": "^16.0.6",
        "terser-webpack-plugin": "^5.3.14",
        "ts-loader": "^9.5.4",
        "typescript": "^5.9.3",
        "webpack": "^5.103.0",
        "webpack-cli": "^6.0.1"
    },
    "resolutions": {
        "nth-check": "^2.0.1",
        "@types/minimatch": "5.1.2"
    },
    "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}

        "webpack": "5.105.4",
        "webpack-cli": "^6.0.1"
    },
    "resolutions": {
        "nth-check": "^2.0.1",
        "@types/minimatch": "5.1.2",
        "immutable": "^5.1.5",
        "svgo": "^4.0.1"
